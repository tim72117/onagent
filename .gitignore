node_modules/
dist/
*.log
.env
.env.local
.env.*.local

# Go
/backend/server
/backend/onagent
/backend/*.exe

# Compiled onagent CLI binaries bundled into the Skill for zero-setup use —
# built locally per-platform (see SKILL.md), not meant to accumulate in git
# history as opaque, non-delta-compressible blobs every time the CLI changes.
/.claude/skills/onagent-cli-setup/bin/

# Backend runtime artifacts — sessions/ holds end-user conversation
# transcripts (want's per-connection history files) and must never be
# committed; the rest are tool downloads and scratch output.
/backend/sessions/
/backend/tmp/
/backend/.bin/
/backend/workspace/

# Local LLM provider config (base URLs, model names, and historically API
# keys) — machine-specific, not meant to be shared/committed.
/backend/configs/

# apps/landing and apps/console build straight into these two directories
# (see apps/console/vite.config.ts's outDir and cmd/server/web.go's
# //go:embed all:web/{landing,console} — Go's embed can't reach outside its
# own package directory, so this is the only place a build can land for
# go:embed to pick it up). assets/ is pure generated build output and
# never meant to be committed. index.html is trickier: a checked-in
# placeholder must stay tracked (cmd/server/web.go's go:embed fails
# outright on a fully empty directory, and it's how a fresh checkout
# builds at all before anyone runs a frontend build) — but a real
# `npm run build` overwrites that same file locally, so avoid `git add`ing
# it after building unless you specifically mean to update the checked-in
# placeholder's own content (e.g. its explanatory comment).
/backend/cmd/server/web/landing/assets/
/backend/cmd/server/web/console/assets/
